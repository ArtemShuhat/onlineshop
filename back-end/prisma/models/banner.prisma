model Banner {
    id        Int        @id @default(autoincrement())
    url       String
    order     Int        @default(0)
    isActive  Boolean    @default(true)
    slot      BannerSlot @default(FEATURED)
    createdAt DateTime   @default(now())
    updatedAt DateTime   @updatedAt
}

enum BannerSlot {
    FEATURED
    BOTTOM_LEFT
    BOTTOM_RIGHT
}
